## 📝 Phase 6: Package Scripts

### Root package.json
```json
{
  "name": "vellichor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:mobile": "cd mobile/Vellichor && npm run start",
    "dev:desktop": "cd desktop && npm run start",
    "dev:server": "cd server && npm run dev",
    "build:mobile": "cd mobile/Vellichor && npm run build",
    "build:desktop": "cd desktop && npm run make",
    "build:server": "cd server && npm run build",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:mobile\" \"npm run dev:desktop\""
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
```

