## 💻 Phase 2: Desktop App (Electron)

```bash
cd vellichor/desktop
```

### 2.1 Initialize Electron
```bash
npm init -y
npm install electron react react-dom @electron-forge/cli
npx @electron-forge/cli import
```

### 2.2 Install Dependencies
```bash
npm install \
  socket.io-client \
  electron-store \
  robotjs \
  screenshot-desktop \
  @types/robotjs \
  @types/screenshot-desktop
```

### 2.3 Create Main Process
```typescript
// desktop/src/main/index.ts
import { app, BrowserWindow, ipcMain } from 'electron';
import path from 'path';
import Store from 'electron-store';
import { setupHandlers } from './ipc';

// Initialize store
Store.initRenderer();

let mainWindow: BrowserWindow | null = null;

const createWindow = () => {
  mainWindow = new BrowserWindow({
    width: 1200,
    height: 800,
    webPreferences: {
      nodeIntegration: false,
      contextIsolation: true,
      preload: path.join(__dirname, 'preload.js'),
    },
  });

  // Load the app
  if (process.env.NODE_ENV === 'development') {
    mainWindow.loadURL('http://localhost:3000');
    mainWindow.webContents.openDevTools();
  } else {
    mainWindow.loadFile(path.join(__dirname, '../renderer/index.html'));
  }

  // Setup IPC handlers
  setupHandlers(mainWindow);
};

app.whenReady().then(createWindow);

app.on('window-all-closed', () => {
  if (process.platform !== 'darwin') {
    app.quit();
  }
});

app.on('activate', () => {
  if (BrowserWindow.getAllWindows().length === 0) {
    createWindow();
  }
});
```

### 2.4 Create Preload Script
```typescript
// desktop/src/main/preload.ts
import { contextBridge, ipcRenderer } from 'electron';

contextBridge.exposeInMainWorld('electronAPI', {
  // Screen capture
  captureScreen: () => ipcRenderer.invoke('capture:screen'),
  
  // Input control
  sendMouseEvent: (event: any) => ipcRenderer.send('input:mouse', event),
  sendKeyboardEvent: (event: any) => ipcRenderer.send('input:keyboard', event),
  
  // File transfer
  selectFile: () => ipcRenderer.invoke('file:select'),
  saveFile: (data: any) => ipcRenderer.invoke('file:save', data),
  
  // Connection
  connectToDevice: (deviceInfo: any) => ipcRenderer.send('device:connect', deviceInfo),
  
  // Listeners
  onScreenData: (callback: any) => {
    ipcRenderer.on('screen:frame', (_, data) => callback(data));
  },
});
```

### 2.5 Create IPC Handlers
```typescript
// desktop/src/main/ipc/index.ts
import { BrowserWindow, ipcMain, dialog } from 'electron';
import * as robot from 'robotjs';
import screenshot from 'screenshot-desktop';
import { writeFile } from 'fs/promises';

export const setupHandlers = (mainWindow: BrowserWindow) => {
  // Screen capture
  ipcMain.handle('capture:screen', async () => {
    try {
      const img = await screenshot({ format: 'png' });
      return img.toString('base64');
    } catch (error) {
      console.error('Screen capture failed:', error);
      return null;
    }
  });

  // Mouse control
  ipcMain.on('input:mouse', (_, event) => {
    const { type, x, y, button } = event;
    
    switch (type) {
      case 'move':
        robot.moveMouse(x, y);
        break;
      case 'click':
        robot.mouseClick(button || 'left');
        break;
      case 'drag':
        robot.dragMouse(x, y);
        break;
      case 'scroll':
        robot.scrollMouse(x, y);
        break;
    }
  });

  // Keyboard control
  ipcMain.on('input:keyboard', (_, event) => {
    const { type, key, modifiers } = event;
    
    if (type === 'keydown') {
      robot.keyTap(key, modifiers);
    }
  });

  // File selection
  ipcMain.handle('file:select', async () => {
    const result = await dialog.showOpenDialog(mainWindow, {
      properties: ['openFile', 'multiSelections'],
    });
    return result.filePaths;
  });

  // File save
  ipcMain.handle('file:save', async (_, { name, data }) => {
    const result = await dialog.showSaveDialog(mainWindow, {
      defaultPath: name,
    });
    
    if (!result.canceled && result.filePath) {
      const buffer = Buffer.from(data, 'base64');
      await writeFile(result.filePath, buffer);
      return true;
    }
    return false;
  });
};
```

