## 📦 Phase 4: Shared Code

```bash
cd vellichor/shared
```

### 4.1 Initialize Shared Package
```bash
npm init -y
npm install -D typescript
```

### 4.2 Create Shared Types
```typescript
// shared/src/types/index.ts
export interface Device {
  id: string;
  name: string;
  type: 'mobile' | 'desktop';
  platform: 'ios' | 'android' | 'windows' | 'macos' | 'linux';
  ipAddress?: string;
  status: 'online' | 'offline' | 'busy';
}

export interface ConnectionInfo {
  id: string;
  peerId: string;
  connectionType: 'wifi' | 'p2p' | 'relay';
  status: 'connecting' | 'connected' | 'disconnected';
  quality: number;
  latency: number;
}

export interface StreamConfig {
  width: number;
  height: number;
  fps: number;
  quality: 'low' | 'medium' | 'high';
  codec: 'h264' | 'vp8' | 'vp9';
}

export interface FileTransfer {
  id: string;
  name: string;
  size: number;
  progress: number;
  status: 'pending' | 'transferring' | 'completed' | 'failed';
  direction: 'send' | 'receive';
  timestamp: number;
}

// Protocol messages
export interface SignalingMessage {
  type: 'offer' | 'answer' | 'candidate' | 'bye';
  roomId: string;
  from: string;
  to?: string;
  data: any;
}

export interface ControlMessage {
  type: 'mouse' | 'keyboard' | 'touch' | 'gesture';
  action: string;
  data: any;
  timestamp: number;
}
```

